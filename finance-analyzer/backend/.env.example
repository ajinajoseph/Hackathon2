# ── Django ────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────
# Set DB_ENGINE=mysql to use MySQL, otherwise SQLite is used
DB_ENGINE=sqlite

# MySQL (only needed if DB_ENGINE=mysql)
DB_NAME=finance_analyzer
DB_USER=root
DB_PASSWORD=yourpassword
DB_HOST=127.0.0.1
DB_PORT=3306

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI Keys (optional but recommended) ───────────────────────
# Add at least one for AI features to work
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
