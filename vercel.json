{
  "version": 2,
  "builds": [
    {
      "src": "finance-analyzer/backend/app/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    },
    {
      "src": "finance-analyzer/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "finance-analyzer/backend/app/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "finance-analyzer/frontend/$1"
    }
  ]
}
